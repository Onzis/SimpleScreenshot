<Window x:Class="Screenshoter.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Обновление" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" CornerRadius="6" Background="#2C2C2E">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#3A3A3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DialogButtonAccent" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" CornerRadius="6" Background="#0A84FF">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#3395FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10" Background="#1C1C1E" Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.5" Color="Black"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="Доступно обновление" Foreground="White"
                       FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock x:Name="VersionText" Foreground="#8E8E93"
                       FontSize="12" Margin="0,0,0,14"/>

            <TextBlock Text="Что нового" Foreground="White"
                       FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Border CornerRadius="6" Background="#2C2C2E" BorderBrush="#3A3A3C"
                    BorderThickness="1" Padding="12,10" MaxHeight="240">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="NotesText" Foreground="#D0D0D2"
                               FontSize="12.5" TextWrapping="Wrap" LineHeight="18"/>
                </ScrollViewer>
            </Border>

            <ProgressBar x:Name="Progress" Height="4" Margin="0,14,0,0"
                         Background="#2C2C2E" Foreground="#0A84FF"
                         BorderThickness="0" Visibility="Collapsed"/>
            <TextBlock x:Name="StatusText" Foreground="#8E8E93" FontSize="11"
                       Margin="2,6,0,0" MinHeight="14"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="BtnLater" Content="Позже" Width="90" Height="32"
                        Margin="0,0,10,0" Style="{StaticResource DialogButton}"/>
                <Button x:Name="BtnUpdate" Content="Обновить" Width="130" Height="32"
                        Style="{StaticResource DialogButtonAccent}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
